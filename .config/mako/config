# Style
font=JetBrainsMono Nerd Font 12
width=400
height=100
outer-margin=8
margin=4
padding=12
border-size=1
border-radius=12
progress-color=over #F2F2F2

# Colors
background-color=#14141940
text-color=#F2F2F2
border-color=#00000033

# General
max-history=100
sort=-time
layer=overlay
anchor=top-right

# Actions
actions=1
on-button-left=invoke-default-action
on-button-middle=none
on-button-right=dismiss
on-touch=dismiss

# Icons
icon-path=/usr/share/icons/Papirus-Dark:/usr/share/icons/breeze:/usr/share/icons/hicolor
max-icon-size=24
icons=1
icon-location=left

# Text
markup=1
format=<b>%s</b>\n%b
text-alignment=left
default-timeout=5000
ignore-timeout=0

# Criteria-based theming
[urgency=low]
border-color=#14141940
default-timeout=2000

[urgency=normal]
border-color=#F2F2F240
default-timeout=5000

[urgency=high]
background-color=#FF5555
border-color=#FF5555
text-color=#F2F2F2
default-timeout=0

[app-name="Screenshot"]
format=<b>%s</b>
default-timeout=3000