{
    "layer": "top",
    "position": "top",
    "spacing": 0,
    "margin-left": 12,
    "margin-right": 12,
    "margin-bottom": 0,
    "margin-top": 4,
    
    "modules-left": [
        "clock",
        "hyprland/workspaces"
    ],
    
    "modules-center": [
        "hyprland/window"
    ],
    
    "modules-right": [
        "backlight",
        "pulseaudio",
        "cpu",
        "memory",
        "battery",
        "tray"
    ],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
        "tooltip": true,
        "tooltip-format": "Workspace: {name}\nWindows: {windows}"
    },

    "hyprland/window": {
        "max-length": 50,
        "separate-outputs": true,
        "tooltip": true,
        "tooltip-format": "App ID: {app_id}\nTitle: {title}"
    },

    "clock": {
        "format": "󰃭 {:%Y-%m-%d   %H:%M:%S}",
        "format-alt": "󰃭 {:%m-%d   %H:%M}",
        "interval": 1,
        "tooltip": false
    },

    "cpu": {
        "format": " {usage}%",
        "states": {
            "warning": 70,
            "critical": 90
        },
        "interval": 1,
        "tooltip": false
    },
    
    "memory": {
        "format": " {percentage}%",
        "states": {
            "warning": 70,
            "critical": 90
        },
        "interval": 1,
        "tooltip": true,
        "tooltip-format": "RAM: {used:0.1f}GB/{total:0.1f}GB ({percentage}%)\nSwap: {swapUsed:0.1f}GB/{swapTotal:0.1f}GB\nAvailable: {avail:0.1f}GB"
    },

    "network": {
        "format-wifi": "󰤨",
        "format-ethernet": "",
        "format-disconnected": "󰪎",
        "tooltip": true,
        "tooltip-format": "Interface: {ifname}\nIP: {ipaddr}/{cidr}\nGateway: {gwaddr}\n\nUp: {bandwidthUpBytes}\nDown: {bandwidthDownBytes}",
        "tooltip-format-wifi": "SSID: {essid}\nSignal: {signalStrength}%\nFreq: {frequency}MHz\n\nInterface: {ifname}\nIP: {ipaddr}/{cidr}\nGateway: {gwaddr}\n\nUp: {bandwidthUpBytes}\nDown: {bandwidthDownBytes}",
        "tooltip-format-ethernet": "Interface: {ifname}\nIP: {ipaddr}/{cidr}\nGateway: {gwaddr}\n\nUp: {bandwidthUpBytes}\nDown: {bandwidthDownBytes}",
        "tooltip-format-disconnected": "Network Disconnected",
        "interval": 1
    },

    "pulseaudio": {
        "format": "󰕾 {volume}%",
        "format-muted": "󰝟 {volume}%",
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol",
        "tooltip": true,
        "tooltip-format": "Volume: {volume}%\nDefault Sink: {desc}",
        "scroll-step": 5
    },

    "tray": {
        "spacing": 10,
        "icon-size": 15,
        "tooltip": true,
        "tooltip-format": "System Tray"
    },

    "battery": {
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": "󱟢 {capacity}%",
        "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "tooltip": true,
        "tooltip-format": "Capacity: {capacity}%\nTime remaining: {time}"
    },
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["󰃞", "󰃟", "󰃠"],
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-",
        "min-length": 6
    }
}
